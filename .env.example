# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# --- Telegram (Phase 0) ---

# From @BotFather on Telegram (use /token or /newbot)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Principals (multi-user allowlist) ---
#
# JSON array of authorized humans. Required keys per entry: user_id (int) +
# name (string). Optional: is_owner=true on exactly one entry — that
# principal receives the daily retrospective and proactive nudges. If
# omitted, the first principal is treated as owner.
#
# Format must be a single line of valid JSON. Example with two users:
#   YUNAM_PRINCIPALS=[{"user_id":6022344291,"name":"jaekeun","is_owner":true},{"user_id":8699080746,"name":"yoolim"}]
#
# Authorization rule: the sender's Telegram user_id must match an entry. In
# group chats, yunam additionally requires an explicit @bot mention or a
# reply to one of its prior messages — non-mention chatter is silently
# ignored even from authorized principals (per Q1=b in the multi-user
# rollout). DMs work normally for any authorized principal.
#
# Get a user_id by DMing @userinfobot on Telegram from the target account.
YUNAM_PRINCIPALS=

# Legacy single-user fallback. If YUNAM_PRINCIPALS is set, this is ignored.
# Kept here for first-time setup / single-user dev — the gateway synthesizes
# a principal named "jaekeun" with is_owner=true from this value.
TELEGRAM_ALLOWED_USER_ID=

# Allowed group/supergroup chat_ids (DMs are always allowed for principals).
# Empty / unset → group chats are entirely disabled. The principal allowlist
# alone isn't enough for groups: even an authorized user mentioning the bot
# in a random group room would otherwise reach yunam. Adding chat_ids here is
# what activates a specific room.
#
# Two accepted forms:
#   JSON array: YUNAM_ALLOWED_CHATS=[-1001234567890,-1009876543210]
#   CSV:        YUNAM_ALLOWED_CHATS=-1001234567890,-1009876543210
#
# How to discover a chat_id when creating a new group:
#   1. Add @yunambot to the group
#   2. From an authorized principal, send `/chatid@yunambot` (or `/chatid` if
#      privacy mode is off). Yunam echoes the chat_id and tells you it's not
#      yet on the allowlist.
#   3. Append that chat_id to this var, then `docker compose restart gateway`.
#
# Telegram chat_ids: positive for users (DMs, == user_id), negative integers
# for groups, large negatives starting with `-100` for supergroups/channels.
YUNAM_ALLOWED_CHATS=

# Group-chat trigger words (vocative aliases). A group message starting with
# any of these (followed by whitespace, punctuation, or end-of-message) is
# treated as if the user typed `@<bot_username>` — saves typing the long
# Telegram bot handle in every message.
#
#   유남아 일정 알려줘   →  treated as `@AgentYunamBot 일정 알려줘`
#   yunam, 잘 지냈어?    →  treated as `@AgentYunamBot 잘 지냈어?`
#
# Comma-separated. Leave UNSET to use the built-in default
# (yunam, Yunam, 유남, 유남아, 유남이). Set to empty string to disable
# triggers entirely and require @bot mentions.
#
# Example with a personal nickname added:
#   YUNAM_GROUP_TRIGGERS=yunam,유남,유남아,유남씨
YUNAM_GROUP_TRIGGERS=

# --- Claude API (Phase 1) ---

# From https://console.anthropic.com/. Required.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Voyage AI (Phase 1 — file embeddings) ---

# From https://dash.voyageai.com/. Used for multimodal embeddings of files
# you save via Telegram — enables semantic search ("find that whiteboard photo").
VOYAGE_API_KEY=pa-your-voyage-key-here

# --- Text embedder selection ---
# Which provider to use for TEXT-ONLY embeddings (memory recall, curation
# scoring/search, conversation turn embeddings). Choices:
#   voyage  (default) — voyage-multimodal-3 against VOYAGE_API_KEY.
#   jina    — jina-embeddings-v3 against JINA_API_KEY (free tier ~1M tok/mo).
# File / image embeddings always stay on Voyage (Jina v3 is text-only). If
# you've exhausted Voyage's free quota for text embeddings, switch to jina —
# only photo/file saves will keep calling Voyage.
YUNAM_TEXT_EMBEDDER=voyage

# --- Volumes & permissions (Phase 1) ---

# Host path to your Obsidian vault. Bind-mounted read/write into the container.
# Create the directory first (`mkdir -p ~/obsidian`). Can point at an existing
# Obsidian Sync folder.
YUNAM_VAULT_PATH_HOST=~/obsidian

# Host path for binary attachments sent through Telegram (photos, documents,
# videos, voice notes, etc). Kept separate from the Obsidian vault so binaries
# don't pollute your notes. Create the directory first (`mkdir -p ~/filevault`).
YUNAM_FILEVAULT_PATH_HOST=~/filevault

# UID/GID that files written by the container should be owned by on the host.
# On Ubuntu 24 VPS (your primary deploy target), the first user is uid 1000 —
# leave these at 1000.
# On macOS for local dev: run `id -u` and `id -g`, paste the real values here
# (typically 501/20 for a standard mac user). If mismatched, vault writes fail
# with a permissions error.
PUID=1000
PGID=1000

# --- Timezone ---

# IANA timezone name used for date stamps in user messages, /diary, and reminders.
YUNAM_TIMEZONE=Asia/Seoul

# --- Web browsing (Phase 2 — web skill) ---

# Optional. Jina Reader (URL fetch) works keyless. Jina Search (keyword search)
# requires a key — without one, web_search falls back to DuckDuckGo HTML
# scraping (free, slightly less reliable). Set this to enable Jina Search.
# Get a free key at https://jina.ai/reader — the free tier quota is generous.
JINA_API_KEY=

# --- Korean skills (Phase 2 — k-skill bundle) ---

# Parcel tracking — Sweet Tracker free API (1000 requests/day).
# Sign up at http://info.sweettracker.co.kr/apikey/add (1-min, 무료).
# Without this the parcel_track tool will return a friendly onboarding error.
# Air quality (Open-Meteo) needs no key.
SWEETTRACKER_API_KEY=

# --- Google Calendar (M3 — MCP integration) ---

# URL of the nspady google-calendar-mcp sibling container (streamable-http).
# Docker-compose-internal hostname = service name. Leave EMPTY to disable
# the gcal skill entirely (useful before OAuth is set up).
# Example: http://calendar-mcp:3000/mcp
YUNAM_GCAL_MCP_URL=

# --- Stock Agent (M3 — MCP integration) ---

# URL of the stock-mcp sibling container (SSE transport).
# Example: http://stock-mcp:3001/sse
YUNAM_STOCK_MCP_URL=

# KRX Data Portal credentials for institutional supply/demand analysis.
# Sign up at https://data.krx.co.kr
KRX_ID=
KRX_PW=

# --- Audit & cost tracking (Phase 2.0 — usage skill) ---

# USD limits the cost_alert_status() tool compares against. The usage skill
# reports 'ok' / 'near limit' (>=80% of either threshold) / 'over limit'
# (>=100% of either). Pure soft-alarm — no hard cutoff. Adjust as needed.
YUNAM_COST_ALERT_DAILY_USD=5.0
YUNAM_COST_ALERT_MONTHLY_USD=100.0

# --- Curation pipeline (Phase 2.1 — news/market feed) ---
#
# Background runner that fetches from Naver / Toss Invest / RSS / Stock-Agent
# every hour, summarizes with Haiku, scores against the interest profile, and
# either pushes URGENT items immediately or queues them for the 21:00
# newsletter. The agent only reads / admins via the `curation` skill — it
# can't trigger a fetch itself.

# Flip to `true` to start the runner alongside the gateway. Leave unset to
# disable the runner entirely (in-conversation curation tools still work —
# they just have no data yet).
YUNAM_CURATION_ENABLED=

# How often (minutes) the runner fans out to sources. 60 is the milestone
# default; tune later when you can see cost in `usage_summary`.
YUNAM_CURATION_INTERVAL_MINUTES=60

# Routing thresholds against the cosine-similarity-ish score in [0, 1].
# >= URGENT_THRESHOLD → immediate Telegram push to owner DM.
# >= DIGEST_THRESHOLD → bundled into the 21:00 newsletter.
# < DIGEST_THRESHOLD → stored but not surfaced (for later analysis).
YUNAM_CURATION_URGENT_THRESHOLD=0.82
YUNAM_CURATION_DIGEST_THRESHOLD=0.55

# Newsletter fire time in local tz (YUNAM_TIMEZONE). "21:00" = 9 PM Seoul.
YUNAM_CURATION_NEWSLETTER_TIME=21:00

# --- Sources ---

# Naver Search OpenAPI — register an application at
# https://developers.naver.com/apps/#/list (free, generous quota). Both ID and
# SECRET required. If either is unset OR YUNAM_CURATION_NAVER_QUERIES is empty,
# the Naver source is skipped.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# Comma-separated query strings. One API call per query per tick.
# Example: AI,반도체,한국 금리,연준
YUNAM_CURATION_NAVER_QUERIES=

# Comma-separated RSS / Atom feeds. Three tiers with different fetch cadences
# to control cost: HIGH every tick, MID every 2nd tick, LOW every 4th tick.
# Tick 1 always fires every tier (so first-tick coverage isn't gated).
#
# Tier HIGH — never miss these (central banks, newswires, regulators):
#   https://news.einfomax.co.kr/rss/allArticle.xml
#   https://www.federalreserve.gov/feeds/press_all.xml
#   https://www.bok.or.kr/portal/bbs/B0000217/rss.do
YUNAM_CURATION_RSS_TIER_HIGH=
# Tier MID — solid general financial news (DJ MarketWatch, Reuters, CNBC, FT,
# 한경 finance, 매경, 조선비즈 stocks, 연합뉴스 finance, NY Fed markets).
YUNAM_CURATION_RSS_TIER_MID=
# Tier LOW — specialized / noisier feeds (Benzinga, Nasdaq earnings, ForexLive,
# ETF.com, Digitimes, TradingEconomics, CoinDesk).
YUNAM_CURATION_RSS_TIER_LOW=
# Legacy single-tier var. If set AND YUNAM_CURATION_RSS_TIER_HIGH is empty,
# treated as tier HIGH (every tick). Prefer the tier-specific vars above.
YUNAM_CURATION_RSS_FEEDS=

# Toss Invest news fetch mode:
#   api         (recommended) — call the internal JSON endpoint directly.
#   playwright  — render the SPA in a Chromium sidecar (NOT YET WIRED).
#   disabled    — skip Toss entirely.
YUNAM_TOSS_FETCH_MODE=api
# Override only if Toss changes their internal API path. The default below
# is the common WTS feed path inferred from the public Next.js client.
YUNAM_TOSS_NEWS_URL=https://wts-info-api.tossinvest.com/api/v2/feed/news

# X / Twitter source — STUB. The plan is a logged-in playwright sidecar
# scraping a burner account's home timeline; the infrastructure isn't up yet
# so this just no-ops with a one-shot warning. See `runners/sources/x_playwright.py`
# for the integration checklist.
YUNAM_X_ENABLED=
# Comma-separated handles to scrape from (empty = home timeline).
YUNAM_X_HANDLES=

# Moneyflow pull from Stock-Agent MCP — calls `analyze_supply` once per tick
# and stores the result as a curated item. Requires YUNAM_STOCK_MCP_URL set.
# Set to `false` to disable even when the MCP is connected.
YUNAM_CURATION_MONEYFLOW=true

# Per-item summary character cap (defensive — Haiku usually stays well under).
YUNAM_CURATION_SUMMARY_MAX_CHARS=320
